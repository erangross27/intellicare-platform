/* TableDocument Template - Generic table styling */

.table-document {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.document-title {
  font-size: 32px;
  font-weight: 600;
  color: #343541;
  margin: 0 0 24px 0;
  padding-bottom: 16px;
  border-bottom: 3px solid #4a9eff;
}

/* Table container with scroll */
.table-container {
  overflow-x: auto;
  background: #2d2e38;
  border: 1px solid #565869;
  border-radius: 8px;
}

/* Data table */
.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}

.data-table thead {
  background: #4a9eff;
  color: #2d2e38;
  position: sticky;
  top: 0;
  z-index: 1;
}

.data-table th {
  padding: 12px;
  text-align: left;
  font-weight: 600;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  white-space: nowrap;
}

.data-table tbody tr {
  border-bottom: 1px solid #565869;
}

.data-table tbody tr:hover {
  background: #ececf1;
}

.data-table tbody tr:last-child {
  border-bottom: none;
}

.data-table td {
  padding: 12px;
  color: #343541;
  vertical-align: top;
}

/* Key-value list (fallback when no table) */
.key-value-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  background: #2d2e38;
  border: 1px solid #565869;
  border-radius: 8px;
  padding: 20px;
}

.key-value-row {
  display: flex;
  gap: 16px;
  padding: 12px;
  background: #2d2e38;
  border-radius: 4px;
  border-left: 3px solid #4a9eff;
}

.key {
  font-weight: 600;
  color: #555;
  min-width: 200px;
  flex-shrink: 0;
}

.value {
  color: #343541;
  flex: 1;
}

/* Empty state */
.empty-state {
  padding: 40px;
  text-align: center;
  color: #999;
}

/* Responsive */
@media (max-width: 768px) {
  .document-title {
    font-size: 24px;
  }

  .data-table {
    font-size: 12px;
  }

  .data-table th,
  .data-table td {
    padding: 8px;
  }

  .key {
    min-width: 120px;
  }
}

/* Print styles */
@media print {
  .table-container {
    border: 1px solid #000;
  }

  .data-table thead {
    background: #565869;
    color: #000;
  }

  .data-table tbody tr:hover {
    background: transparent;
  }
}
