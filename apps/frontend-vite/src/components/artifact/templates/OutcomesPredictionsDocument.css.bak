.outcomes-predictions-document {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  line-height: 1.6;
  color: #343541;
  max-width: 100%;
  padding: 24px;
}

.outcomes-predictions-document .document-header {
  border-bottom: 3px solid #5e35b1;
  padding-bottom: 16px;
  margin-bottom: 24px;
}

.outcomes-predictions-document .document-header h2 {
  margin: 0 0 8px 0;
  color: #5e35b1;
  font-size: 28px;
  font-weight: 600;
}

.outcomes-predictions-document .document-date {
  color: #c5c5d2;
  font-size: 14px;
}

.outcomes-predictions-document .patient-info-section {
  background: #ececf1;
  padding: 16px;
  border-radius: 8px;
  margin-bottom: 24px;
}

.outcomes-predictions-document .patient-info-section h3 {
  margin: 0 0 12px 0;
  font-size: 18px;
  color: #ececf1;
}

.outcomes-predictions-document .patient-info-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 12px;
}

.outcomes-predictions-document .prognosis-section {
  margin-bottom: 32px;
  padding: 24px;
  background: linear-gradient(135deg, #4a9eff 0%, #764ba2 100%);
  color: white;
  border-radius: 8px;
}

.outcomes-predictions-document .prognosis-section h3 {
  margin: 0 0 16px 0;
  font-size: 22px;
  color: white;
}

.outcomes-predictions-document .prognosis-content {
  font-size: 16px;
  line-height: 1.8;
}

.outcomes-predictions-document .section {
  margin-bottom: 32px;
  padding: 20px;
  background: #fff;
  border-radius: 8px;
  border: 2px solid #7b1fa2;
}

.outcomes-predictions-document .section h3 {
  margin: 0 0 16px 0;
  font-size: 22px;
  color: #7b1fa2;
}

.outcomes-predictions-document .factors-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 16px;
}

.outcomes-predictions-document .factor-card {
  background: #f3e5f5;
  padding: 16px;
  border-radius: 6px;
  border-left: 4px solid #7b1fa2;
}

.outcomes-predictions-document .factor-name {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 12px;
  color: #7b1fa2;
}

.outcomes-predictions-document .factor-impact,
.outcomes-predictions-document .factor-intervention {
  margin-top: 8px;
  font-size: 14px;
  color: #444;
}

.outcomes-predictions-document .expected-outcomes-section {
  margin-bottom: 24px;
  padding: 20px;
  background: #e8f5e9;
  border-radius: 8px;
  border: 2px solid #388e3c;
}

.outcomes-predictions-document .expected-outcomes-section h3 {
  margin: 0 0 16px 0;
  font-size: 22px;
  color: #2e7d32;
}

.outcomes-predictions-document .outcomes-content {
  font-size: 15px;
  line-height: 1.8;
  color: #343541;
}

.outcomes-predictions-document .document-footer {
  margin-top: 32px;
  padding-top: 16px;
  border-top: 1px solid #ddd;
}

.outcomes-predictions-document .source-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 13px;
  color: #c5c5d2;
}

.outcomes-predictions-document .ai-badge {
  background: #e3f2fd;
  color: #1565c0;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 600;
}
