                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                        </svg>
                        {copiedCardId === `med-stop-${idx}` ? 'Copied!' : 'Copy'}
                      </button>
                    </div>
                    {med.reason && (
                      <div className="card-details">
                        <div className="detail-item">
                          <span className="detail-label">Reason</span>
                          <span className="detail-value">{highlightText(med.reason)}</span>
                        </div>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}

          {filteredMedModified.length > 0 && (
            <div>
              <h3 className="section-title" style={{ fontSize: '18px', color: '#ea580c' }}>
                🔧 {highlightText(`Modified (${filteredMedModified.length})`)}
              </h3>
              <div className="cards-grid">
                {filteredMedModified.map((med, idx) => (
                  <div key={idx} className="ai-card" style={{ borderLeft: '4px solid #ea580c' }}>
                    <div className="card-header">
                      <h4 className="card-title">{highlightText(med.medication || med.name)}</h4>
                      <button onClick={() => copyCard(med, `med-mod-${idx}`)} className="copy-btn-inline" title="Copy">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                        </svg>
                        {copiedCardId === `med-mod-${idx}` ? 'Copied!' : 'Copy'}
                      </button>
                    </div>
                    {med.change && (
                      <div className="card-details">
                        <div className="detail-item">
                          <span className="detail-label">Change</span>
                          <span className="detail-value">{highlightText(med.change)}</span>
                        </div>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}
        </section>
      )}

      {/* Consultation Details */}
      {filteredConsultations.length > 0 && (
        <section className="ai-section">
          <h2 className="section-title">
            <span className="section-icon">👨‍⚕️</span>
            {highlightText('Consultation Details')}
          </h2>
          <div className="cards-grid">
            {filteredConsultations.map((consult, idx) => (
              <div key={idx} className="ai-card">
                <div className="card-header">
                  <h4 className="card-title">{highlightText(consult.consultingSpecialty || 'Consultation')}</h4>
                  <button onClick={() => copyCard(consult, 'consultation')} className="copy-btn-inline" title="Copy">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                    {copiedCardId === 'consultation' ? 'Copied!' : 'Copy'}
                  </button>
                </div>
                <div className="card-details">
                  {consult.consultDate && (
                    <div className="detail-item">
                      <span className="detail-label">Consult Date</span>
                      <span className="detail-value">{formatDate(consult.consultDate)}</span>
                    </div>
                  )}
                  {consult.consultingPhysician && (
                    <div className="detail-item">
                      <span className="detail-label">Consulting Physician</span>
                      <span className="detail-value">{highlightText(consult.consultingPhysician)}</span>
                    </div>
                  )}
                  {consult.referringPhysician && (
                    <div className="detail-item">
                      <span className="detail-label">Referring Physician</span>
                      <span className="detail-value">{highlightText(consult.referringPhysician)}</span>
                    </div>
                  )}
                  {consult.reasonForConsult && (
                    <div className="detail-item">
                      <span className="detail-label">Reason for Consult</span>
                      <span className="detail-value">{highlightText(consult.reasonForConsult)}</span>
                    </div>
                  )}
                  {consult.physicianCredentials && (
                    <div className="detail-item">
                      <span className="detail-label">Credentials</span>
                      <span className="detail-value">{highlightText(consult.physicianCredentials)}</span>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Providers Section */}
      {!searchTerm && document.providers && (
        <section className="ai-section">
          <h2 className="section-title">
            <span className="section-icon">👥</span>
            Care Team
          </h2>
          <div className="cards-grid">
            {document.providers.primary && (
              <div className="ai-card">
                <div className="card-details">
                  <div className="detail-item">
                    <span className="detail-label">Primary Physician</span>
                    <span className="detail-value">{document.providers.primary}</span>
                  </div>
                </div>
              </div>
            )}
            {document.providers.consulting && document.providers.consulting.length > 0 && (
              <div className="ai-card">
                <h4 className="card-title" style={{ marginBottom: '12px' }}>Consultants</h4>
                <div className="card-details">
                  {document.providers.consulting.map((consultant, idx) => (
                    <div key={idx} className="detail-item">
                      <span className="detail-label">{document.providers.consultingSpecialties?.[idx] || 'Consultant'}</span>
                      <span className="detail-value">{consultant}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </section>
      )}

      {/* Administrative Data */}
      {!searchTerm && document.administrativeData && Object.keys(document.administrativeData).length > 0 && (
        <section className="ai-section">
          <h2 className="section-title">
            <span className="section-icon">📄</span>
            Administrative Data
          </h2>
          <div className="ai-card">
            <div className="card-details">
              {document.administrativeData.mrn && (
                <div className="detail-item">
                  <span className="detail-label">Medical Record Number</span>
                  <span className="detail-value">{document.administrativeData.mrn}</span>
                </div>
              )}
              {document.administrativeData.admissionDate && (
                <div className="detail-item">
                  <span className="detail-label">Admission Date</span>
                  <span className="detail-value">{formatDate(document.administrativeData.admissionDate)}</span>
                </div>
              )}
              {document.administrativeData.dischargeDate && (
                <div className="detail-item">
                  <span className="detail-label">Discharge Date</span>
                  <span className="detail-value">{formatDate(document.administrativeData.dischargeDate)}</span>
                </div>
              )}
              {document.administrativeData.lengthOfStay && (
                <div className="detail-item">
                  <span className="detail-label">Length of Stay</span>
                  <span className="detail-value">{document.administrativeData.lengthOfStay}</span>
                </div>
              )}
              {document.administrativeData.disposition && (
                <div className="detail-item">
                  <span className="detail-label">Disposition</span>
                  <span className="detail-value">{document.administrativeData.disposition}</span>
                </div>
              )}
              {document.administrativeData.electronicSignature && (
                <div className="detail-item">
                  <span className="detail-label">Electronic Signature</span>
                  <span className="detail-value">{document.administrativeData.electronicSignature}</span>
                </div>
              )}
            </div>
          </div>
        </section>
      )}

      {/* Trending Analysis */}
      {filteredTrends.length > 0 && (
        <section className="ai-section">
          <h2 className="section-title">
            <span className="section-icon">📈</span>
            {highlightText(`Trending Analysis (${filteredTrends.length})`)}
          </h2>
          <div className="cards-grid">
            {filteredTrends.map((trend, idx) => (
              <div key={idx} className="ai-card">
                <div className="card-header">
                  <h4 className="card-title">{highlightText(trend.parameter)}</h4>
                  <button onClick={() => copyCard(trend, `trend-${idx}`)} className="copy-btn-inline" title="Copy">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                    {copiedCardId === `trend-${idx}` ? 'Copied!' : 'Copy'}
                  </button>
                </div>
                <div className="card-details">
                  {trend.direction && (
                    <div className="detail-item">
                      <span className="detail-label">Direction</span>
                      <span className="detail-value">{highlightText(trend.direction)}</span>
                    </div>
                  )}
                  {trend.clinicalSignificance && (
                    <div className="detail-item">
                      <span className="detail-label">Clinical Significance</span>
                      <span className="detail-value">{highlightText(trend.clinicalSignificance)}</span>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Patient-Specific Care Plan */}
      {filteredCareInterventions.length > 0 && (
        <section className="ai-section">
          <h2 className="section-title">
            <span className="section-icon">🎯</span>
            {highlightText(`Patient-Specific Care Plan (${filteredCareInterventions.length})`)}
          </h2>
          <div className="cards-grid">
            {filteredCareInterventions.map((intervention, idx) => (
              <div key={idx} className="ai-card">
                <div className="card-header">
                  <h4 className="card-title">{highlightText(intervention.intervention)}</h4>
                  <button onClick={() => copyCard(intervention, `care-${idx}`)} className="copy-btn-inline" title="Copy">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                    {copiedCardId === `care-${idx}` ? 'Copied!' : 'Copy'}
                  </button>
                </div>
                {intervention.rationale && (
                  <div className="card-details">
                    <div className="detail-item">
                      <span className="detail-label">Rationale</span>
                      <span className="detail-value">{highlightText(intervention.rationale)}</span>
                    </div>
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Medications Optimizations */}
      {filteredMedOpt.length > 0 && (
        <section className="ai-section">
          <h2 className="section-title">
            <span className="section-icon">⚡</span>
            {highlightText(`Medications Optimizations (${filteredMedOpt.length})`)}
          </h2>
          <div className="cards-grid">
            {filteredMedOpt.map((opt, idx) => (
              <div key={idx} className="ai-card">
                <div className="card-header">
                  <h4 className="card-title">{highlightText(opt.medication)}</h4>
                  <button onClick={() => copyCard(opt, `med-opt-${idx}`)} className="copy-btn-inline" title="Copy">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                    {copiedCardId === `med-opt-${idx}` ? 'Copied!' : 'Copy'}
                  </button>
                </div>
                <div className="card-details">
                  {opt.recommendation && (
                    <div className="detail-item">
                      <span className="detail-label">Recommendation</span>
                      <span className="detail-value">{highlightText(opt.recommendation)}</span>
                    </div>
                  )}
                  {opt.rationale && (
                    <div className="detail-item">
                      <span className="detail-label">Rationale</span>
                      <span className="detail-value">{highlightText(opt.rationale)}</span>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Doctor's Medications Recommendations Optimizations */}
      {filteredDocMedOpt.length > 0 && (
        <section className="ai-section">
          <h2 className="section-title">
            <span className="section-icon">💡</span>
            {highlightText(`New Prescriptions Analysis (${filteredDocMedOpt.length})`)}
          </h2>
          <div className="cards-grid">
            {filteredDocMedOpt.map((opt, idx) => (
              <div key={idx} className="ai-card">
                <div className="card-header">
                  <h4 className="card-title">{highlightText(opt.medication)}</h4>
                  <button onClick={() => copyCard(opt, `doc-opt-${idx}`)} className="copy-btn-inline" title="Copy">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                    {copiedCardId === `doc-opt-${idx}` ? 'Copied!' : 'Copy'}
                  </button>
                </div>
                <div className="card-details">
                  {opt.recommendation && (
                    <div className="detail-item">
                      <span className="detail-label">Recommendation</span>
                      <span className="detail-value">{highlightText(opt.recommendation)}</span>
                    </div>
                  )}
                  {opt.rationale && (
                    <div className="detail-item">
                      <span className="detail-label">Rationale</span>
                      <span className="detail-value">{highlightText(opt.rationale)}</span>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Follow-Up Intelligence */}
      {filteredFollowUpIntel.length > 0 && (
        <section className="ai-section">
          <h2 className="section-title">
            <span className="section-icon">📋</span>
            {highlightText(`Follow-Up Intelligence (${filteredFollowUpIntel.length})`)}
          </h2>
          <div className="cards-grid">
            {filteredFollowUpIntel.map((task, idx) => (
              <div key={idx} className="ai-card">
                <div className="card-header" style={{ flexDirection: 'column', gap: '12px' }}>
                  <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', width: '100%' }}>
                    <div className="priority-number">{task.priority || idx + 1}</div>
                    <div style={{ display: 'flex', gap: '8px', alignItems: 'center' }}>
                      {task.urgency && (
                        <span className={`urgency-badge ${task.urgency.toLowerCase().includes('high') ? 'urgency-high' : task.urgency.toLowerCase().includes('important') ? 'urgency-important' : 'urgency-routine'}`}>
                          {task.urgency}
                        </span>
                      )}
                      <button onClick={() => copyCard(task, `followup-${idx}`)} className="copy-btn-inline" title="Copy">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                        </svg>
                        {copiedCardId === `followup-${idx}` ? 'Copied!' : 'Copy'}
                      </button>
                    </div>
                  </div>
                  <h4 className="card-title" style={{ margin: 0 }}>{highlightText(task.task)}</h4>
                </div>
                {task.importance && (
                  <div className="card-details">
                    <div className="detail-item">
                      <span className="detail-label">Importance</span>
                      <span className="detail-value">{highlightText(task.importance)}</span>
                    </div>
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Patient Education Context */}
      {filteredEduContext.length > 0 && (
        <section className="ai-section">
          <h2 className="section-title">
            <span className="section-icon">📚</span>
            {highlightText(`Patient Education (${filteredEduContext.length})`)}
          </h2>
          <div className="cards-grid">
            {filteredEduContext.map((topic, idx) => (
              <div key={idx} className="ai-card">
                <div className="card-header">
                  <h4 className="card-title">{highlightText(topic.topic)}</h4>
                  <button onClick={() => copyCard(topic, `edu-${idx}`)} className="copy-btn-inline" title="Copy">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                    {copiedCardId === `edu-${idx}` ? 'Copied!' : 'Copy'}
                  </button>
                </div>
                {topic.keyPoints && topic.keyPoints.length > 0 && (
                  <div className="card-details">
                    <div className="detail-item">
                      <span className="detail-label">Key Points</span>
                      <span className="detail-value">
                        {topic.keyPoints.map((point, pidx) => (
                          <div key={pidx}>{highlightText(`• ${point}`)}</div>
                        ))}
                      </span>
                    </div>
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Empty State */}
      {allItems.length === 0 && (
        <div className="empty-state">
          <div className="empty-icon">📋</div>
          <p className="empty-text">No allergy & immunology data available</p>
        </div>
      )}
    </div>
  );
};

export default AllergyImmunologyDocument;
