# IntelliCare Environment Variables

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/intellicare

# AI Services
CLAUDE_API_KEY=your_claude_api_key_here

# Google Cloud Configuration (for production Vertex AI)
GOOGLE_CLOUD_PROJECT_ID=your_project_id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# Document Encryption (HIPAA Compliance)
# Generate a secure 32-character key for AES-256 encryption
DOCUMENT_ENCRYPTION_KEY=your_32_character_encryption_key_here

# Voice Services
SPEECH_TO_TEXT_API_KEY=your_speech_api_key
TEXT_TO_SPEECH_API_KEY=your_tts_api_key

# Server Configuration
PORT=5000
NODE_ENV=development

# Universal Cache Configuration
# Set to 'false' to disable backend function caching during development
# This does NOT affect external API caching (Claude Prompt Caching, etc.)
# Default: true (enabled)
ENABLE_UNIVERSAL_CACHE=true

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Medical Model Service
MEDGEMMA_SERVICE_URL=http://localhost:5001

# Example encryption key generation (use in production):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
