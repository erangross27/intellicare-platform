{
  "name": "intellicare-backend",
  "version": "1.0.0",
  "description": "Backend for IntelliCare - Intelligent Medical AI Assistant",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:watch": "nodemon --legacy-watch server.js",
    "dev:windows": "nodemon -L server.js",
    "dev:bash": "nodemon --watch . --ext js,json --delay 500 -L --signal SIGTERM server.js",
    "dev:manual": "node server.js",
    "dev:stable": "node server-stable.js",
    "test": "jest --config jest.config.js --setupFiles ./__tests__/setup.js",
    "test:unit": "npm run test",
    "start-medgemma": "python services/mediGemmaMicroservice.py",
    "test:security": "node backend/test-security-enforcement.js",
    "security:check": "node backend/scripts/securityValidator.js",
    "security:fix": "node backend/scripts/autoFixSecurity.js",
    "test:with-auth": "NODE_ENV=test ALLOW_TEST_TOKENS=true npm test",
    "mcp:mongodb": "node scripts/setup-mongodb-mcp.js",
    "mcp:setup": "node scripts/setup-mongodb-mcp.js"
  },
