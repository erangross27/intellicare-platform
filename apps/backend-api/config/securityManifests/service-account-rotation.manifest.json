{
  "serviceId": "service-account-rotation",
  "serviceName": "Service Account Rotation Service",
  "description": "Automatic rotation of service account credentials for enhanced security",
  "permissions": [
    "serviceAccounts:read",
    "serviceAccounts:write",
    "serviceAccounts:rotate",
    "audit:write",
    "security:write",
    "alert:send",
    "credentials:backup",
    "credentials:update"
  ],
  "allowedClinics": [
    "*"
  ],
  "dataAccessPatterns": [
    "serviceAccounts.find({ active: true })",
    "serviceAccounts.update({ credentials })",
    "rotationHistory.insert(rotationEvent)",
    "credentialBackups.insert({ encrypted: true })",
    "auditLogs.insert({ type: \"rotation_event\" })"
  ],
  "schedules": [
    {
      "cron": "0 */1 * * *",
      "description": "Hourly rotation checks"
    },
    {
      "cron": "0 0 */7 * *",
      "description": "Weekly critical service rotation"
    },
    {
      "cron": "0 0 */14 * *",
      "description": "Bi-weekly high priority rotation"
    },
    {
      "cron": "0 0 */30 * *",
      "description": "Monthly standard rotation"
    }
  ],
  "criticality": "critical",
  "requiresMFA": true,
  "allowedOperations": [
    "startRotation",
    "stopRotation",
    "checkRotations",
    "rotateAccount",
    "emergencyRotation",
    "forceRotation",
    "getRotationStatus",
    "generateNewCredentials",
    "backupCredentials",
    "notifyService"
  ],
  "securityRequirements": {
    "encryption": true,
    "audit": true,
    "accessControl": "strict",
    "dataRetention": "3_years",
    "keyManagement": "secure"
  },
  "dependencies": [
    "serviceAccountManager",
    "immutableAuditService",
    "securityMonitoringService",
    "crypto"
  ],
  "integrations": [
    {
      "service": "serviceAccountManager",
      "purpose": "Service account credential management",
      "permissions": ["serviceAccounts:read", "serviceAccounts:write", "credentials:update"]
    },
    {
      "service": "immutableAuditService", 
      "purpose": "Rotation audit logging",
      "permissions": ["audit:write"]
    },
    {
      "service": "securityMonitoringService",
      "purpose": "Security event notifications",
      "permissions": ["alert:send"]
    }
  ],
  "rotationPolicy": {
    "defaultInterval": "30_days",
    "criticalInterval": "7_days",
    "highInterval": "14_days",
    "emergencyInterval": "1_hour",
    "maxHistoryEntries": 10
  },
  "emergencyProtocols": {
    "triggerConditions": [
      "security_breach",
      "credential_compromise",
      "manual_emergency"
    ],
    "rotationScope": "all_accounts",
    "notificationLevel": "critical"
  }
}