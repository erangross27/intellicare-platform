import React, { useState, useRef } from 'react';
import { pdf } from '@react-pdf/renderer';
import { saveAs } from 'file-saver';
import SearchBar from '../components/SearchBar';
import { useDocumentSearch } from '../hooks/useDocumentSearch';
import ReactMarkdown from 'react-markdown';
import './AllergyImmunologyDocument.css';

const AllergyImmunologyDocument = ({ document: rawData }) => {
  const [copiedFeedback, setCopiedFeedback] = useState(null);
  const [copiedCardId, setCopiedCardId] = useState(null);
  const contentRef = useRef(null);

  // Unwrap the allergy_immunology_assessment array if wrapped
  const document = rawData?.allergy_immunology_assessment?.[0] || rawData;

  console.log('🏥 [AllergyImmunologyDocument] Received document:', document);

  // Flatten all searchable items (including static sections)
  const allItems = [
    // Static content sections
    ...(document.chiefComplaint ? [{
      _type: 'static-chief-complaint',
      _searchText: `Chief Complaint ${typeof document.chiefComplaint === 'object' ? document.chiefComplaint.complaint : document.chiefComplaint} ${document.chiefComplaint?.duration || ''}`,
      content: typeof document.chiefComplaint === 'object' ? document.chiefComplaint.complaint : document.chiefComplaint,
      duration: document.chiefComplaint?.duration
    }] : []),
    ...(document.historyOfPresentIllness ? [{
      _type: 'static-hpi',
      _searchText: `History of Present Illness ${document.historyOfPresentIllness}`,
      content: document.historyOfPresentIllness
    }] : []),
    ...(document.physicalExamination ? [{
      _type: 'static-physical-exam',
      _searchText: `Physical Examination ${JSON.stringify(document.physicalExamination)}`,
      content: document.physicalExamination
    }] : []),
    ...(document.vitalSigns ? [{
      _type: 'static-vital-signs',
      _searchText: `Vital Signs ${JSON.stringify(document.vitalSigns)}`,
      content: document.vitalSigns
    }] : []),
    ...(document.pulmonaryFunctionTests ? [{
      _type: 'static-pulmonary',
      _searchText: `Pulmonary Function Tests ${JSON.stringify(document.pulmonaryFunctionTests)}`,
      content: document.pulmonaryFunctionTests
    }] : []),
    ...(document.asthmaAssessment ? [{
      _type: 'static-asthma',
      _searchText: `Asthma Assessment ${JSON.stringify(document.asthmaAssessment)}`,
      content: document.asthmaAssessment
    }] : []),
    ...(document.allergyAssessment ? [{
      _type: 'static-allergy-assessment',
      _searchText: `Allergy Assessment ${JSON.stringify(document.allergyAssessment)}`,
      content: document.allergyAssessment
    }] : []),
    ...(document.allergyImmunologyAssessment ? [{
      _type: 'static-allergy-immunology',
      _searchText: `Allergy Immunology Assessment ${JSON.stringify(document.allergyImmunologyAssessment)}`,
      content: document.allergyImmunologyAssessment
    }] : []),
    ...(document.reviewOfSystems ? [{
      _type: 'static-ros',
      _searchText: `Review of Systems ${JSON.stringify(document.reviewOfSystems)}`,
      content: document.reviewOfSystems
    }] : []),
    ...(document.medicalHistory ? [{
      _type: 'static-medical-history',
      _searchText: `Medical History ${JSON.stringify(document.medicalHistory)}`,
      content: document.medicalHistory
    }] : []),
    ...(document.assessmentAndPlan ? [{
      _type: 'static-assessment-plan',
      _searchText: `Assessment Plan ${document.assessmentAndPlan}`,
      content: document.assessmentAndPlan
    }] : []),
    ...(document.treatmentPlan ? [{
      _type: 'static-treatment-plan',
      _searchText: `Treatment Plan ${typeof document.treatmentPlan === 'string' ? document.treatmentPlan : JSON.stringify(document.treatmentPlan)}`,
      content: document.treatmentPlan
    }] : []),
    ...(document.patientEducation ? [{
      _type: 'static-patient-education',
      _searchText: `Patient Education ${typeof document.patientEducation === 'string' ? document.patientEducation : JSON.stringify(document.patientEducation)}`,
      content: document.patientEducation
    }] : []),
    ...(document.monitoringPlan ? [{
      _type: 'static-monitoring-plan',
      _searchText: `Monitoring Plan ${typeof document.monitoringPlan === 'string' ? document.monitoringPlan : JSON.stringify(document.monitoringPlan)}`,
      content: document.monitoringPlan
    }] : []),
    ...(document.prognosis ? [{
      _type: 'static-prognosis',
      _searchText: `Prognosis ${typeof document.prognosis === 'string' ? document.prognosis : JSON.stringify(document.prognosis)}`,
      content: document.prognosis
    }] : []),

    // Dynamic card-based items (search only in card content, not section names)
    ...(document.allergies || []).map((item, idx) => ({ ...item, _type: 'allergy', _searchText: `${item.allergen} ${item.reaction} ${item.severity} ${item.type || ''}`, _idx: idx })),
    ...(document.medications || []).map((item, idx) => ({ ...item, _type: 'medication', _searchText: `${item.name} ${item.dosage} ${item.frequency} ${item.indication || ''}`, _idx: idx })),
    ...(document.labResults || []).map((item, idx) => ({ ...item, _type: 'lab', _searchText: `${item.testName} ${item.value} ${item.interpretation || ''}`, _idx: idx })),
    ...(document.diagnoses || []).map((item, idx) => ({ ...item, _type: 'diagnosis', _searchText: `${item.diagnosis} ${item.icdCode || ''} ${item.type || ''}`, _idx: idx })),
    ...(document.followUpAppointments || []).map((item, idx) => ({ ...item, _type: 'followup', _searchText: `${item.specialty} ${item.reason} ${item.timing || ''}`, _idx: idx })),
    ...(document.referrals || []).map((item, idx) => ({ ...item, _type: 'referral', _searchText: `${item.specialty} ${item.reason} ${item.urgency || ''}`, _idx: idx })),
    ...(document.imaging || []).map((item, idx) => ({ ...item, _type: 'imaging', _searchText: `${item.type || item.study} ${item.findings || ''}`, _idx: idx })),
    ...(document.clinicalDecisionSupport?.redFlags || []).map((item, idx) => ({ ...item, _type: 'redflag', _searchText: `${item.finding} ${item.urgency} ${item.action || ''}`, _idx: idx })),
    ...(document.clinicalDecisionSupport?.drugInteractions || []).map((item, idx) => ({ ...item, _type: 'druginteraction', _searchText: `${item.medications?.join(' ')} ${item.clinicalEffect || ''}`, _idx: idx })),
    ...(document.clinicalDecisionSupport?.contraindications || []).map((item, idx) => ({ ...item, _type: 'contraindication', _searchText: `${item.medication || item.name} ${item.condition || ''}`, _idx: idx })),
    ...(document.intelligentRecommendations?.immediate || []).map((item, idx) => ({ ...item, _type: 'rec-immediate', _searchText: `${item.action} ${item.rationale || ''}`, _idx: idx })),
    ...(document.intelligentRecommendations?.shortTerm || []).map((item, idx) => ({ ...item, _type: 'rec-short', _searchText: `${item.action} ${item.rationale || ''}`, _idx: idx })),
    ...(document.intelligentRecommendations?.longTerm || []).map((item, idx) => ({ ...item, _type: 'rec-long', _searchText: `${item.goal || item.action} ${item.timeline || ''}`, _idx: idx })),

    // New sections - 11 missing fields
    ...(document.doctorsMedicationsRecommendations || []).map((item, idx) => ({ ...item, _type: 'doc-med-rec', _searchText: `${item.medication || item.name} ${item.dosage || ''} ${item.indication || ''}`, _idx: idx })),
    ...(document.medicationChanges?.started || []).map((item, idx) => ({ ...item, _type: 'med-started', _searchText: `Started ${item.medication || item.name} ${item.dosage || ''}`, _idx: idx })),
    ...(document.medicationChanges?.stopped || []).map((item, idx) => ({ ...item, _type: 'med-stopped', _searchText: `Stopped ${item.medication || item.name} ${item.reason || ''}`, _idx: idx })),
    ...(document.medicationChanges?.modified || []).map((item, idx) => ({ ...item, _type: 'med-modified', _searchText: `Modified ${item.medication || item.name} ${item.change || ''}`, _idx: idx })),
    // consultationDetails is an object, not array - add as single searchable item
    ...(document.consultationDetails ? [{
      ...document.consultationDetails,
      _type: 'consultation',
      _searchText: `${document.consultationDetails.consultingSpecialty || ''} ${document.consultationDetails.consultingPhysician || ''} ${document.consultationDetails.reasonForConsult || ''}`,
      _idx: 0
    }] : []),
    ...(document.trendingAnalysis?.trends || []).map((item, idx) => ({ ...item, _type: 'trend', _searchText: `${item.parameter} ${item.direction} ${item.clinicalSignificance || ''}`, _idx: idx })),
    ...(document.patientSpecificCarePlan?.interventions || []).map((item, idx) => ({ ...item, _type: 'care-intervention', _searchText: `${item.intervention} ${item.rationale || ''}`, _idx: idx })),
    ...(document.medicationsOptimizations?.optimizations || []).map((item, idx) => ({ ...item, _type: 'med-opt', _searchText: `${item.medication} ${item.recommendation} ${item.rationale || ''}`, _idx: idx })),
    ...(document.doctorsMedicationsRecommendationsOptimizations?.optimizations || []).map((item, idx) => ({ ...item, _type: 'doc-med-opt', _searchText: `${item.medication} ${item.recommendation} ${item.rationale || ''}`, _idx: idx })),
    ...(document.followUpIntelligence?.prioritization || []).map((item, idx) => ({ ...item, _type: 'followup-intel', _searchText: `${item.task} ${item.urgency} ${item.importance || ''}`, _idx: idx })),
    ...(document.patientEducationContext?.topics || []).map((item, idx) => ({ ...item, _type: 'edu-context', _searchText: `${item.topic} ${item.keyPoints?.join(' ') || ''}`, _idx: idx }))
  ];

  // Search hook
  const { searchTerm, setSearchTerm, filteredItems } = useDocumentSearch(
    allItems,
    ['_searchText', 'allergen', 'name', 'testName', 'diagnosis', 'specialty', 'finding', 'action', 'goal']
  );

  // Highlight search term
  const highlightText = (text) => {
    if (!text || !searchTerm.trim()) return text;
    const searchLower = searchTerm.toLowerCase();
    const textLower = text.toLowerCase();
    if (!textLower.includes(searchLower)) return text;

    const parts = [];
    let lastIndex = 0;
    let index = textLower.indexOf(searchLower);

    while (index !== -1) {
      if (index > lastIndex) {
        parts.push(text.substring(lastIndex, index));
      }
      parts.push(
        <mark key={index} style={{ backgroundColor: '#fef08a', color: '#000', padding: '2px 0' }}>
          {text.substring(index, index + searchTerm.length)}
        </mark>
      );
      lastIndex = index + searchTerm.length;
      index = textLower.indexOf(searchLower, lastIndex);
    }

    if (lastIndex < text.length) {
      parts.push(text.substring(lastIndex));
    }

    return parts;
  };

  const formatDate = (dateValue) => {
    if (!dateValue) return 'Not specified';
    try {
      const date = new Date(dateValue);
      return date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      });
    } catch {
      return String(dateValue);
    }
  };

  // Copy Chief Complaint
  const copyChiefComplaint = async () => {
    let text = 'CHIEF COMPLAINT\n';
    text += '═'.repeat(60) + '\n\n';
    text += typeof document.chiefComplaint === 'object' ? document.chiefComplaint.complaint : document.chiefComplaint;
    if (document.chiefComplaint?.duration) {
      text += `\nDuration: ${document.chiefComplaint.duration}`;
    }

    try {
      await navigator.clipboard.writeText(text);
      setCopiedCardId('chief-complaint');
      setTimeout(() => setCopiedCardId(null), 2000);
    } catch (err) {
      console.error('Failed to copy with clipboard API:', err);
      try {
        const textarea = window.document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        textarea.style.pointerEvents = 'none';
        window.document.body.appendChild(textarea);
        textarea.select();
        window.document.execCommand('copy');
        window.document.body.removeChild(textarea);

        setCopiedCardId('chief-complaint');
        setTimeout(() => setCopiedCardId(null), 2000);
      } catch (fallbackErr) {
        console.error('Fallback copy also failed:', fallbackErr);
      }
    }
  };

  // Copy History of Present Illness
  const copyHistoryOfPresentIllness = async () => {
    let text = 'HISTORY OF PRESENT ILLNESS\n';
    text += '═'.repeat(60) + '\n\n';
    text += document.historyOfPresentIllness;

    try {
      await navigator.clipboard.writeText(text);
      setCopiedCardId('hpi');
      setTimeout(() => setCopiedCardId(null), 2000);
    } catch (err) {
      console.error('Failed to copy with clipboard API:', err);
      try {
        const textarea = window.document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        textarea.style.pointerEvents = 'none';
        window.document.body.appendChild(textarea);
        textarea.select();
        window.document.execCommand('copy');
        window.document.body.removeChild(textarea);

        setCopiedCardId('hpi');
        setTimeout(() => setCopiedCardId(null), 2000);
      } catch (fallbackErr) {
        console.error('Fallback copy also failed:', fallbackErr);
      }
    }
  };

  // Copy entire document
  const copyAllText = async () => {
    let text = 'ALLERGY & IMMUNOLOGY ASSESSMENT\n\n';

    if (document.patientName) {
      text += `Patient: ${document.patientName}`;
      if (document.age) text += ` • Age: ${document.age}`;
      if (document.gender) text += ` • Gender: ${document.gender}`;
      if (document.mrn) text += ` • MRN: ${document.mrn}`;
      text += '\n\n';
    }

    if (document.chiefComplaint) {
      text += 'CHIEF COMPLAINT\n';
      text += '═'.repeat(60) + '\n\n';
      text += typeof document.chiefComplaint === 'object' ? document.chiefComplaint.complaint : document.chiefComplaint;
      if (document.chiefComplaint.duration) {
        text += `\nDuration: ${document.chiefComplaint.duration}`;
      }
      text += '\n\n';
    }

    if (document.allergies?.length > 0) {
      text += `ALLERGIES (${document.allergies.length})\n`;
      text += '═'.repeat(60) + '\n\n';
      document.allergies.forEach((allergy, idx) => {
        text += `${idx + 1}. ${allergy.allergen}\n`;
        text += `   Severity: ${allergy.severity || 'Not specified'}\n`;
        text += `   Reaction: ${allergy.reaction}\n`;
        if (allergy.type) text += `   Type: ${allergy.type}\n`;
        if (allergy.onset) text += `   Onset: ${allergy.onset}\n`;
        text += '\n';
      });
    }

    if (document.medications?.length > 0) {
      text += `CURRENT MEDICATIONS (${document.medications.length})\n`;
      text += '═'.repeat(60) + '\n\n';
      document.medications.forEach((med, idx) => {
        text += `${idx + 1}. ${med.name}: ${med.dosage} ${med.frequency}\n`;
        if (med.route) text += `   Route: ${med.route}\n`;
        if (med.indication) text += `   Indication: ${med.indication}\n`;
        if (med.status) text += `   Status: ${med.status}\n`;
        text += '\n';
      });
    }

    if (document.labResults?.length > 0) {
      text += `LAB RESULTS (${document.labResults.length})\n`;
      text += '═'.repeat(60) + '\n\n';
      document.labResults.forEach((lab, idx) => {
        text += `${idx + 1}. ${lab.testName}: ${lab.value} ${lab.unit || ''}\n`;
        if (lab.flag) text += `   Flag: ${lab.flag}\n`;
        if (lab.referenceRange) text += `   Reference: ${lab.referenceRange}\n`;
        if (lab.interpretation) text += `   Interpretation: ${lab.interpretation}\n`;
        text += '\n';
      });
    }

    if (document.diagnoses?.length > 0) {
      text += `DIAGNOSES (${document.diagnoses.length})\n`;
      text += '═'.repeat(60) + '\n\n';
      document.diagnoses.forEach((dx, idx) => {
        text += `${idx + 1}. ${dx.diagnosis}\n`;
        if (dx.icdCode) text += `   ICD Code: ${dx.icdCode}\n`;
        if (dx.type) text += `   Type: ${dx.type}\n`;
        if (dx.status) text += `   Status: ${dx.status}\n`;
        text += '\n';
      });
    }

    if (document.imaging?.length > 0) {
      text += `IMAGING STUDIES (${document.imaging.length})\n`;
      text += '═'.repeat(60) + '\n\n';
      document.imaging.forEach((img, idx) => {
        text += `${idx + 1}. ${img.type || img.study}\n`;
        if (img.date) text += `   Date: ${formatDate(img.date)}\n`;
        if (img.findings) text += `   Findings: ${img.findings}\n`;
        text += '\n';
      });
    }

    if (document.followUpAppointments?.length > 0) {
      text += `FOLLOW-UP APPOINTMENTS (${document.followUpAppointments.length})\n`;
      text += '═'.repeat(60) + '\n\n';
      document.followUpAppointments.forEach((appt, idx) => {
        text += `${idx + 1}. ${appt.specialty}\n`;
        text += `   Reason: ${appt.reason}\n`;
        if (appt.timing) text += `   Timing: ${appt.timing}\n`;
        if (appt.urgency) text += `   Urgency: ${appt.urgency}\n`;
        text += '\n';
      });
    }

    if (document.referrals?.length > 0) {
      text += `REFERRALS (${document.referrals.length})\n`;
      text += '═'.repeat(60) + '\n\n';
      document.referrals.forEach((ref, idx) => {
        text += `${idx + 1}. ${ref.specialty}\n`;
        text += `   Reason: ${ref.reason}\n`;
        if (ref.urgency) text += `   Urgency: ${ref.urgency}\n`;
        if (ref.status) text += `   Status: ${ref.status}\n`;
        text += '\n';
      });
    }

    if (document.clinicalDecisionSupport?.redFlags?.length > 0) {
      text += `CLINICAL DECISION SUPPORT - RED FLAGS (${document.clinicalDecisionSupport.redFlags.length})\n`;
      text += '═'.repeat(60) + '\n\n';
      document.clinicalDecisionSupport.redFlags.forEach((flag, idx) => {
        text += `${idx + 1}. ${flag.finding}\n`;
        text += `   Urgency: ${flag.urgency}\n`;
        if (flag.action) text += `   Action: ${flag.action}\n`;
        text += '\n';
      });
    }

    if (document.clinicalDecisionSupport?.drugInteractions?.length > 0) {
      text += `CLINICAL DECISION SUPPORT - DRUG INTERACTIONS (${document.clinicalDecisionSupport.drugInteractions.length})\n`;
      text += '═'.repeat(60) + '\n\n';
      document.clinicalDecisionSupport.drugInteractions.forEach((interaction, idx) => {
        text += `${idx + 1}. ${interaction.medications?.join(' + ')}\n`;
        text += `   Severity: ${interaction.severity}\n`;
        if (interaction.clinicalEffect) text += `   Effect: ${interaction.clinicalEffect}\n`;
        if (interaction.recommendation) text += `   Recommendation: ${interaction.recommendation}\n`;
        text += '\n';
      });
    }

    if (document.intelligentRecommendations?.immediate?.length > 0) {
      text += `INTELLIGENT RECOMMENDATIONS - IMMEDIATE ACTIONS (${document.intelligentRecommendations.immediate.length})\n`;
      text += '═'.repeat(60) + '\n\n';
      document.intelligentRecommendations.immediate.forEach((rec, idx) => {
        text += `${idx + 1}. ${rec.action}\n`;
        if (rec.rationale) text += `   Rationale: ${rec.rationale}\n`;
        text += '\n';
      });
    }

    try {
      await navigator.clipboard.writeText(text);
      setCopiedFeedback('all');
      setTimeout(() => setCopiedFeedback(null), 2000);
    } catch (err) {
      console.error('Failed to copy with clipboard API:', err);
      // Fallback method for older browsers
      try {
        const textarea = window.document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        textarea.style.pointerEvents = 'none';
        window.document.body.appendChild(textarea);
        textarea.select();
        window.document.execCommand('copy');
        window.document.body.removeChild(textarea);

        setCopiedFeedback('all');
        setTimeout(() => setCopiedFeedback(null), 2000);
      } catch (fallbackErr) {
        console.error('Fallback copy also failed:', fallbackErr);
      }
    }
  };

  // Copy entire section
  const copySection = async (sectionTitle, sectionData, id) => {
    let text = `${sectionTitle.toUpperCase()}\n${'═'.repeat(60)}\n\n`;

    const formatSectionData = (data, indent = 0) => {
      const indentStr = '  '.repeat(indent);

      // Handle arrays
      if (Array.isArray(data)) {
        let result = '';
        data.forEach((item, idx) => {
          if (typeof item === 'object' && item !== null) {
            result += `${indentStr}[${idx + 1}]\n`;
            Object.entries(item)
              .filter(([k]) => !k.startsWith('_'))
              .forEach(([k, v]) => {
                const displayKey = k.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase());
                if (typeof v === 'object' && v !== null) {
                  result += `${indentStr}  ${displayKey}:\n`;
                  result += formatSectionData(v, indent + 2);
                } else {
                  result += `${indentStr}  ${displayKey}: ${v}\n`;
                }
              });
            result += '\n';
          } else {
            result += `${indentStr}• ${item}\n`;
          }
        });
        return result;
      }

      // Handle objects
      if (typeof data === 'object' && data !== null) {
        let result = '';
        Object.entries(data)
          .filter(([k]) => !k.startsWith('_'))
          .forEach(([key, value]) => {
            const displayKey = key.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase());

            if (typeof value === 'object' && value !== null) {
              result += `${indentStr}${displayKey}:\n`;
              result += formatSectionData(value, indent + 1);
              result += '\n';
            } else {
              result += `${indentStr}${displayKey}: ${value}\n`;
            }
          });
        return result;
      }

      // Simple value
      return `${indentStr}${data}\n`;
    };

    text += formatSectionData(sectionData);

    try {
      await navigator.clipboard.writeText(text);
      setCopiedCardId(id);
      setTimeout(() => setCopiedCardId(null), 2000);
    } catch (err) {
      console.error('Failed to copy section:', err);
      try {
        const textarea = window.document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        textarea.style.pointerEvents = 'none';
        window.document.body.appendChild(textarea);
        textarea.select();
        window.document.execCommand('copy');
        window.document.body.removeChild(textarea);

        setCopiedCardId(id);
        setTimeout(() => setCopiedCardId(null), 2000);
      } catch (fallbackErr) {
        console.error('Fallback copy also failed:', fallbackErr);
      }
    }
  };

  // Copy individual card
  const copyCard = async (item, id) => {
    console.log('[AllergyImmunologyDocument] copyCard called with:', { item, id });
    let text = '';

    if (item._type === 'allergy') {
      text = `${item.allergen}\nSeverity: ${item.severity || 'Not specified'}\nReaction: ${item.reaction}`;
      if (item.type) text += `\nType: ${item.type}`;
      if (item.onset) text += `\nOnset: ${item.onset}`;
    } else if (item._type === 'medication') {
      text = `${item.name}: ${item.dosage} ${item.frequency}`;
      if (item.route) text += `\nRoute: ${item.route}`;
      if (item.indication) text += `\nIndication: ${item.indication}`;
      if (item.status) text += `\nStatus: ${item.status}`;
    } else if (item._type === 'lab') {
      text = `${item.testName}: ${item.value} ${item.unit || ''}`;
      if (item.flag) text += `\nFlag: ${item.flag}`;
      if (item.referenceRange) text += `\nReference: ${item.referenceRange}`;
      if (item.interpretation) text += `\nInterpretation: ${item.interpretation}`;
    } else if (item._type === 'diagnosis') {
      text = `${item.diagnosis}`;
      if (item.icdCode) text += `\nICD Code: ${item.icdCode}`;
      if (item.type) text += `\nType: ${item.type}`;
      if (item.status) text += `\nStatus: ${item.status}`;
    } else if (item._type === 'followup') {
      text = `${item.specialty}\nReason: ${item.reason}`;
      if (item.timing) text += `\nTiming: ${item.timing}`;
      if (item.urgency) text += `\nUrgency: ${item.urgency}`;
    } else if (item._type === 'referral') {
      text = `${item.specialty}\nReason: ${item.reason}`;
      if (item.urgency) text += `\nUrgency: ${item.urgency}`;
      if (item.status) text += `\nStatus: ${item.status}`;
    } else if (item._type === 'imaging') {
      text = `${item.type || item.study}`;
      if (item.date) text += `\nDate: ${formatDate(item.date)}`;
      if (item.findings) text += `\nFindings: ${item.findings}`;
    } else if (item._type === 'redflag') {
      text = `${item.finding}\nUrgency: ${item.urgency}`;
      if (item.action) text += `\nAction: ${item.action}`;
    } else if (item._type === 'druginteraction') {
      text = `${item.medications?.join(' + ')}\nSeverity: ${item.severity}`;
      if (item.clinicalEffect) text += `\nEffect: ${item.clinicalEffect}`;
      if (item.recommendation) text += `\nRecommendation: ${item.recommendation}`;
    } else if (item._type === 'contraindication') {
      text = `${item.medication || item.name}\nSeverity: ${item.severity}`;
      if (item.condition) text += `\nCondition: ${item.condition}`;
      if (item.reason) text += `\nReason: ${item.reason}`;
      if (item.alternative) text += `\nAlternative: ${item.alternative}`;
    } else if (item._type === 'rec-immediate') {
      text = `${item.action}`;
      if (item.rationale) text += `\nRationale: ${item.rationale}`;
    } else if (item._type === 'rec-short') {
      text = `${item.action}`;
      if (item.rationale) text += `\nRationale: ${item.rationale}`;
    } else if (item._type === 'rec-long') {
      text = `${item.goal || item.action}`;
      if (item.timeline) text += `\nTimeline: ${item.timeline}`;
    } else if (item._type === 'structured') {
      // Handle structured data from renderStructuredCards
      text = `${item.key}\n${'═'.repeat(40)}\n\n`;

      const formatStructuredValue = (val, indent = 0) => {
        const indentStr = '  '.repeat(indent);

        // Handle arrays
        if (Array.isArray(val)) {
          let result = '';
          val.forEach((item, idx) => {
            if (typeof item === 'object' && item !== null) {
              result += `${indentStr}[${idx + 1}]\n`;
              Object.entries(item).forEach(([k, v]) => {
                const displayKey = k.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase());
                if (typeof v === 'object' && v !== null) {
                  result += `${indentStr}  ${displayKey}:\n`;
                  result += formatStructuredValue(v, indent + 2);
                } else {
                  result += `${indentStr}  ${displayKey}: ${v}\n`;
                }
              });
            } else {
              result += `${indentStr}• ${item}\n`;
            }
          });
          return result;
        }

        // Handle objects
        if (typeof val === 'object' && val !== null) {
          let result = '';
          Object.entries(val).forEach(([k, v]) => {
            const displayKey = k.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase());
            if (typeof v === 'object' && v !== null) {
              result += `${indentStr}${displayKey}:\n`;
              result += formatStructuredValue(v, indent + 1);
            } else {
              result += `${indentStr}${displayKey}: ${v}\n`;
            }
          });
          return result;
        }

        // Simple value
        return `${indentStr}${val}\n`;
      };

      text += formatStructuredValue(item.value);
    }

    console.log('[AllergyImmunologyDocument] Text to copy:', text);

    try {
      await navigator.clipboard.writeText(text);
      console.log('[AllergyImmunologyDocument] Copy successful via clipboard API');
      setCopiedCardId(id);
      setTimeout(() => setCopiedCardId(null), 2000);
    } catch (err) {
      console.error('[AllergyImmunologyDocument] Failed to copy with clipboard API:', err);
      // Fallback method for older browsers
      try {
        const textarea = window.document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        textarea.style.pointerEvents = 'none';
        window.document.body.appendChild(textarea);
        textarea.select();
        window.document.execCommand('copy');
        window.document.body.removeChild(textarea);

        console.log('[AllergyImmunologyDocument] Copy successful via fallback method');
        setCopiedCardId(id);
        setTimeout(() => setCopiedCardId(null), 2000);
      } catch (fallbackErr) {
        console.error('[AllergyImmunologyDocument] Fallback copy also failed:', fallbackErr);
      }
    }
  };

  // Export to PDF
  const exportToPDF = async () => {
    try {
      setCopiedFeedback('exporting');

      const { default: AllergyImmunologyPDFTemplate } = await import('../pdf-templates/AllergyImmunologyPDFTemplate');

      const blob = await pdf(
        <AllergyImmunologyPDFTemplate
          documents={[document]}
          patientName={document.patientName}
        />
      ).toBlob();

      const fileName = `AllergyImmunology_${new Date().toISOString().split('T')[0]}.pdf`;
      saveAs(blob, fileName);

      setCopiedFeedback('exported');
      setTimeout(() => setCopiedFeedback(null), 2000);
    } catch (err) {
      console.error('Failed to export PDF:', err);
      alert(`PDF Export Error: ${err.message}`);
    }
  };

  // Render severity badge
  const renderSeverityBadge = (severity) => {
    if (!severity) return null;
    const severityLower = severity.toLowerCase();
    let className = '';

    if (severityLower.includes('critical') || severityLower.includes('severe') || severityLower.includes('high')) {
      className = 'severity-critical';
    } else if (severityLower.includes('moderate') || severityLower.includes('important')) {
      className = 'severity-moderate';
    } else {
      className = 'severity-low';
    }

    return <span className={`severity-badge ${className}`}>{severity.toUpperCase()}</span>;
  };

  // Render lab flag badge
  const renderLabFlagBadge = (flag) => {
    if (!flag) return null;
    const flagLower = flag.toLowerCase();
    let className = '';

    if (flagLower.includes('h') || flagLower.includes('high') || flagLower.includes('abnormal') || flagLower.includes('critical')) {
      className = 'severity-critical';
    } else if (flagLower.includes('l') || flagLower.includes('low') || flagLower.includes('borderline')) {
      className = 'severity-moderate';
    } else if (flagLower.includes('normal')) {
      className = 'severity-low';
    } else {
      className = 'severity-low';
    }

    return <span className={`severity-badge ${className}`}>{flag.toUpperCase()}</span>;
  };

  // Render nested object as readable format with search highlighting
  const renderObject = (obj, excludeFields = []) => {
    if (!obj || typeof obj !== 'object') return null;

    const entries = Object.entries(obj).filter(
      ([key]) => !excludeFields.includes(key) && !key.startsWith('_')
    );

    if (entries.length === 0) return null;

    return (
      <div className="nested-fields">
        {entries.map(([key, value]) => (
          <div key={key} className="field-row">
            <span className="field-label">
              {highlightText(key.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase()))}:
            </span>
            <span className="field-value">
              {typeof value === 'object' && value !== null
                ? renderObject(value)
                : highlightText(String(value))}
            </span>
          </div>
        ))}
      </div>
    );
  };

  // Render markdown with search highlighting
  const renderMarkdownWithHighlight = (text) => {
    if (!searchTerm || !text) {
      return <ReactMarkdown>{text}</ReactMarkdown>;
    }

    // For simple highlighting in markdown, we'll render the markdown
    // and wrap it in a div that highlights the search term
    const highlighted = highlightText(text);

    // If highlighting occurred (returns array), render as text
    // Otherwise render as markdown
    if (Array.isArray(highlighted)) {
      return <div style={{ whiteSpace: 'pre-wrap' }}>{highlighted}</div>;
    }

    return <ReactMarkdown>{text}</ReactMarkdown>;
  };

  // Render structured data as full-width row cards (like CDS template)
  const renderStructuredCards = (obj, sectionId) => {
    if (!obj || typeof obj !== 'object') return null;

    const entries = Object.entries(obj).filter(
      ([key]) => !key.startsWith('_')
    );

    if (entries.length === 0) return null;

    return (
      <div style={{ display: 'flex', flexDirection: 'column', gap: '12px' }}>
        {entries.map(([key, value], idx) => {
          const displayKey = key.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase());

          // Render nested object as detail items
          const renderDetailItems = (val) => {
            // Handle arrays
            if (Array.isArray(val)) {
              return (
                <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }}>
                  {val.map((item, itemIdx) => {
                    if (typeof item === 'object' && item !== null) {
                      // Render object array items as mini-cards
                      return (
                        <div
                          key={itemIdx}
                          style={{
                            background: '#2d2d2d',
                            padding: '12px',
                            borderRadius: '6px',
                            border: '1px solid #565869'
                          }}
                        >
                          {Object.entries(item)
                            .filter(([k]) => !k.startsWith('_'))
                            .map(([k, v]) => (
                              <div key={k} style={{ marginBottom: '4px' }}>
                                <span style={{ fontWeight: '600', color: '#10a37f', fontSize: '14px' }}>
                                  {highlightText(k.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase()))}:
                                </span>
                                <span style={{ marginLeft: '8px', color: '#ececf1', fontSize: '14px' }}>
                                  {typeof v === 'object' && v !== null ? JSON.stringify(v) : highlightText(String(v))}
                                </span>
                              </div>
                            ))}
                        </div>
                      );
                    }
                    // Simple array item (string/number)
                    return (
                      <div key={itemIdx} style={{ color: '#ececf1', fontSize: '14px', paddingLeft: '12px' }}>
                        • {highlightText(String(item))}
                      </div>
                    );
                  })}
                </div>
              );
            }

            // Handle nested objects
            if (typeof val === 'object' && val !== null) {
              return Object.entries(val)
                .filter(([k]) => !k.startsWith('_'))
                .map(([k, v]) => {
                  const nestedDisplayKey = k.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase());

                  // If nested value is also an object or array, render recursively
                  if (typeof v === 'object' && v !== null) {
                    return (
                      <div key={k} style={{ marginBottom: '12px' }}>
                        <div style={{ fontWeight: '600', color: '#10a37f', fontSize: '15px', marginBottom: '8px' }}>
                          {highlightText(nestedDisplayKey)}:
                        </div>
                        <div style={{ paddingLeft: '16px' }}>
                          {renderDetailItems(v)}
                        </div>
                      </div>
                    );
                  }

                  return (
                    <div key={k} className="detail-item" style={{ marginBottom: '8px' }}>
                      <span className="detail-label" style={{ fontWeight: '600', color: '#10a37f' }}>
                        {highlightText(nestedDisplayKey)}:
                      </span>
                      <span className="detail-value" style={{ marginLeft: '8px', color: '#ececf1' }}>
                        {highlightText(String(v))}
                      </span>
                    </div>
                  );
                });
            }

            // Simple value
            return (
              <div style={{ color: '#ececf1', fontSize: '15px', lineHeight: '1.6' }}>
                {highlightText(String(val))}
              </div>
            );
          };

          return (
            <div
              key={key}
              className="ai-card"
              style={{
                padding: '20px',
                background: '#343541',
                borderRadius: '8px',
                border: '1px solid #565869'
              }}
            >
              {/* Title row */}
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '12px' }}>
                <h3 style={{ margin: 0, fontSize: '16px', fontWeight: '700', color: '#ececf1' }}>
                  {highlightText(displayKey)}
                </h3>
                <button
                  onClick={() => copyCard({ _type: 'structured', key: displayKey, value: value }, `${sectionId}-${idx}`)}
                  style={{
                    background: 'transparent',
                    color: '#9ca3af',
                    border: '1px solid #565869',
                    borderRadius: '6px',
                    padding: '6px 10px',
                    fontSize: '12px',
                    fontWeight: '600',
                    cursor: 'pointer',
                    display: 'flex',
                    alignItems: 'center',
                    gap: '4px',
                    transition: 'all 0.2s',
                    flexShrink: 0,
                    minWidth: '85px',
                    justifyContent: 'center'
                  }}
                  onMouseEnter={(e) => {
                    e.currentTarget.style.background = '#40414f';
                    e.currentTarget.style.color = '#ececf1';
                  }}
                  onMouseLeave={(e) => {
                    e.currentTarget.style.background = 'transparent';
                    e.currentTarget.style.color = '#9ca3af';
                  }}
                  title="Copy this item"
                >
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                  {copiedCardId === `${sectionId}-${idx}` ? 'Copied!' : 'Copy'}
                </button>
              </div>

              {/* Content area */}
              <div style={{ paddingLeft: '4px' }}>
                {renderDetailItems(value)}
              </div>
            </div>
          );
        })}
      </div>
    );
  };

  // Severity sorting
  const getSeverityScore = (level) => {
    if (!level) return 0;
    const levelLower = level.toLowerCase();
    if (levelLower.includes('critical') || levelLower.includes('severe')) return 5;
    if (levelLower.includes('high')) return 4;
    if (levelLower.includes('moderate')) return 3;
    if (levelLower.includes('low')) return 2;
    if (levelLower.includes('mild')) return 1;
    return 0;
  };

  // Filter items by type
  const filteredAllergies = filteredItems
    .filter(item => item._type === 'allergy')
    .sort((a, b) => getSeverityScore(b.severity) - getSeverityScore(a.severity));

  const filteredMedications = filteredItems.filter(item => item._type === 'medication');
  const filteredLabs = filteredItems
    .filter(item => item._type === 'lab')
    .sort((a, b) => {
      const flagOrder = { h: 5, high: 5, abnormal: 4, l: 3, low: 3, borderline: 2 };
      const aFlag = (a.flag?.toLowerCase()?.trim()) || 'normal';
      const bFlag = (b.flag?.toLowerCase()?.trim()) || 'normal';
      const aOrder = flagOrder[aFlag] ?? 0;
      const bOrder = flagOrder[bFlag] ?? 0;
      return bOrder - aOrder;
    });
  const filteredDiagnoses = filteredItems.filter(item => item._type === 'diagnosis');
  const filteredFollowUps = filteredItems.filter(item => item._type === 'followup');
  const filteredReferrals = filteredItems.filter(item => item._type === 'referral');
  const filteredImaging = filteredItems.filter(item => item._type === 'imaging');
  const filteredRedFlags = filteredItems.filter(item => item._type === 'redflag');
  const filteredDrugInteractions = filteredItems.filter(item => item._type === 'druginteraction');
  const filteredContraindications = filteredItems.filter(item => item._type === 'contraindication');
  const filteredRecImmediate = filteredItems.filter(item => item._type === 'rec-immediate');
  const filteredRecShort = filteredItems.filter(item => item._type === 'rec-short');
  const filteredRecLong = filteredItems.filter(item => item._type === 'rec-long');

  // New filtered arrays for 11 missing sections
  const filteredDocMedRec = filteredItems.filter(item => item._type === 'doc-med-rec');
  const filteredMedStarted = filteredItems.filter(item => item._type === 'med-started');
  const filteredMedStopped = filteredItems.filter(item => item._type === 'med-stopped');
  const filteredMedModified = filteredItems.filter(item => item._type === 'med-modified');
  const filteredConsultations = filteredItems.filter(item => item._type === 'consultation');
  const filteredTrends = filteredItems.filter(item => item._type === 'trend');
  const filteredCareInterventions = filteredItems.filter(item => item._type === 'care-intervention');
  const filteredMedOpt = filteredItems.filter(item => item._type === 'med-opt');
  const filteredDocMedOpt = filteredItems.filter(item => item._type === 'doc-med-opt');
  const filteredFollowUpIntel = filteredItems.filter(item => item._type === 'followup-intel');
  const filteredEduContext = filteredItems.filter(item => item._type === 'edu-context');

  // Filter static sections - only show if no search OR if section matches search
  const showChiefComplaint = !searchTerm || filteredItems.some(item => item._type === 'static-chief-complaint');
  const showHPI = !searchTerm || filteredItems.some(item => item._type === 'static-hpi');
  const showPhysicalExam = !searchTerm || filteredItems.some(item => item._type === 'static-physical-exam');
  const showVitalSigns = !searchTerm || filteredItems.some(item => item._type === 'static-vital-signs');
  const showPulmonary = !searchTerm || filteredItems.some(item => item._type === 'static-pulmonary');
  const showAsthma = !searchTerm || filteredItems.some(item => item._type === 'static-asthma');
  const showAllergyAssessment = !searchTerm || filteredItems.some(item => item._type === 'static-allergy-assessment');
  const showAllergyImmunology = !searchTerm || filteredItems.some(item => item._type === 'static-allergy-immunology');
  const showROS = !searchTerm || filteredItems.some(item => item._type === 'static-ros');
  const showMedicalHistory = !searchTerm || filteredItems.some(item => item._type === 'static-medical-history');
  const showAssessmentPlan = !searchTerm || filteredItems.some(item => item._type === 'static-assessment-plan');
  const showTreatmentPlan = !searchTerm || filteredItems.some(item => item._type === 'static-treatment-plan');
  const showPatientEducation = !searchTerm || filteredItems.some(item => item._type === 'static-patient-education');
  const showMonitoringPlan = !searchTerm || filteredItems.some(item => item._type === 'static-monitoring-plan');
  const showPrognosis = !searchTerm || filteredItems.some(item => item._type === 'static-prognosis');

  // Debug logging
  if (searchTerm) {
    console.log('🔍 [Search Debug]', {
      searchTerm,
      totalItems: allItems.length,
      filteredCount: filteredItems.length,
      filteredTypes: filteredItems.map(i => i._type),
      showFlags: {
        showChiefComplaint,
        showHPI,
        showPhysicalExam,
        showMedicalHistory,
        showAllergyAssessment
      }
    });
  }

  // Check if we have any results when searching
  const hasSearchResults = !searchTerm || filteredItems.length > 0;

  return (
    <div className="allergy-immunology-document" ref={contentRef}>
      {/* Document Header */}
      <div className="ai-document-header">
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>
          <h1 className="ai-document-title">Allergy & Immunology Assessment</h1>

          {/* Action Buttons - On the right side */}
          <div style={{ display: 'flex', gap: '6px' }}>
            {/* Copy All Button */}
            <button
              onClick={copyAllText}
              className="action-btn"
              title="Copy all"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              {copiedFeedback === 'all' ? 'Copied!' : 'Copy All'}
            </button>

            {/* Export PDF Button */}
            <button
              onClick={exportToPDF}
              className="action-btn"
              title="Export to PDF"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="12" y1="18" x2="12" y2="12"/>
                <line x1="9" y1="15" x2="15" y2="15"/>
              </svg>
              {copiedFeedback === 'exported' ? 'Exported!' : copiedFeedback === 'exporting' ? 'Exporting...' : 'Export PDF'}
            </button>
          </div>
        </div>

        {document.date && <p className="ai-document-date">{formatDate(document.date)}</p>}
        {document.patientName && (
          <div className="document-meta">
            <strong>Patient:</strong> {document.patientName}
            {document.age && ` • Age: ${document.age}`}
            {document.gender && ` • Gender: ${document.gender}`}
            {document.dateOfBirth && ` • DOB: ${document.dateOfBirth}`}
            {document.mrn && ` • MRN: ${document.mrn}`}
          </div>
        )}
      </div>

      {/* Search Bar */}
      <SearchBar
        searchTerm={searchTerm}
        onSearchChange={setSearchTerm}
        placeholder="Search allergies, medications, labs, diagnoses, recommendations..."
        totalCount={allItems.length}
        filteredCount={filteredItems.length}
      />

      {/* Empty Search State */}
      {filteredItems.length === 0 && searchTerm && (
        <div className="empty-state">
          <div className="empty-icon">🔍</div>
          <p className="empty-text">No results found for "{searchTerm}"</p>
        </div>
      )}

      {/* Chief Complaint */}
      {showChiefComplaint && document.chiefComplaint && (
        <section className="ai-section">
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '16px' }}>
            <h2 className="chief-complaint-title section-title" style={{ marginBottom: 0 }}>
              <span className="section-icon">🚨</span>
              {highlightText('Chief Complaint')}
            </h2>
            <button
              onClick={copyChiefComplaint}
              style={{
                background: 'transparent',
                color: '#9ca3af',
                border: '1px solid #565869',
                borderRadius: '6px',
                padding: '6px 10px',
                fontSize: '12px',
                fontWeight: '600',
                cursor: 'pointer',
                display: 'flex',
                alignItems: 'center',
                gap: '4px',
                transition: 'all 0.2s',
                flexShrink: 0,
                minWidth: '85px',
                justifyContent: 'center'
              }}
              onMouseEnter={(e) => {
                e.currentTarget.style.background = '#40414f';
                e.currentTarget.style.color = '#ececf1';
              }}
              onMouseLeave={(e) => {
                e.currentTarget.style.background = 'transparent';
                e.currentTarget.style.color = '#9ca3af';
              }}
              title="Copy chief complaint"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              {copiedCardId === 'chief-complaint' ? 'Copied!' : 'Copy'}
            </button>
          </div>
          <div className="chief-complaint-card">
            <p className="complaint-text">
              {highlightText(typeof document.chiefComplaint === 'object' ? document.chiefComplaint.complaint : document.chiefComplaint)}
            </p>
            {document.chiefComplaint.duration && (
              <p className="complaint-duration">
                <strong>Duration:</strong> {highlightText(document.chiefComplaint.duration)}
              </p>
            )}
          </div>
        </section>
      )}

      {/* History of Present Illness */}
      {showHPI && document.historyOfPresentIllness && (
        <section className="ai-section">
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '16px' }}>
            <h2 className="section-title" style={{ marginBottom: 0 }}>
              <span className="section-icon">📋</span>
              {highlightText('History of Present Illness')}
            </h2>
            <button
              onClick={copyHistoryOfPresentIllness}
              style={{
                background: 'transparent',
                color: '#9ca3af',
                border: '1px solid #565869',
                borderRadius: '6px',
                padding: '6px 10px',
                fontSize: '12px',
                fontWeight: '600',
                cursor: 'pointer',
                display: 'flex',
                alignItems: 'center',
                gap: '4px',
                transition: 'all 0.2s',
                flexShrink: 0,
                minWidth: '85px',
                justifyContent: 'center'
              }}
              onMouseEnter={(e) => {
                e.currentTarget.style.background = '#40414f';
                e.currentTarget.style.color = '#ececf1';
              }}
              onMouseLeave={(e) => {
                e.currentTarget.style.background = 'transparent';
                e.currentTarget.style.color = '#9ca3af';
              }}
