/* Dark theme matching AIDocumentRenderer.css */
.anesthesia-document {
  padding: 32px;
  background: #343541;
  color: #e2e8f0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  line-height: 1.6;
}

/* Document Title */
.document-title {
  font-size: 28px;
  font-weight: 700;
  color: #e2e8f0;
  margin: 0 0 16px 0;
  padding-bottom: 12px;
  border-bottom: 2px solid #565869;
}

/* Document Metadata */
.document-meta {
  background: #40414f;
  padding: 12px 16px;
  border-radius: 8px;
  margin-bottom: 24px;
  font-size: 14px;
  color: #c5c5d2;
  border: 1px solid #565869;
}

/* Sections */
.doc-section {
  margin-bottom: 32px;
  background: #40414f;
  border: 1px solid #565869;
  border-radius: 12px;
  padding: 20px;
  transition: all 0.2s;
}

.doc-section:hover {
  border-color: #10a37f;
  box-shadow: 0 4px 12px rgba(16, 163, 127, 0.1);
}

.doc-section.highlight-section {
  border-left: 4px solid #10a37f;
  background: rgba(16, 163, 127, 0.05);
}

.section-title {
  font-size: 20px;
  font-weight: 700;
  color: #e2e8f0;
  margin: 0 0 16px 0;
  padding-bottom: 8px;
  border-bottom: 1px solid #565869;
}

.section-content {
  font-size: 15px;
  color: #c5c5d2;
}

.subsection {
  margin-top: 16px;
  padding: 16px;
  background: #343541;
  border-radius: 8px;
  border: 1px solid #565869;
}

.subsection-title {
  font-size: 16px;
  font-weight: 600;
  color: #e2e8f0;
  margin: 0 0 12px 0;
}

/* Field Rows */
.field-row {
  margin-bottom: 12px;
  display: flex;
  gap: 12px;
  color: #c5c5d2;
}

.field-label {
  font-weight: 600;
  color: #e2e8f0;
  min-width: 180px;
}

.field-value {
  flex: 1;
  color: #c5c5d2;
}

/* Special Styling - ASA Classification */
.asa-class {
  font-size: 18px;
  padding: 12px 16px;
  background: rgba(239, 68, 68, 0.1);
  border-left: 4px solid #ef4444;
  border-radius: 8px;
  margin-bottom: 16px;
  color: #e2e8f0;
}

/* Risk Assessment */
.risk-assessment {
  padding: 12px 16px;
  background: rgba(245, 158, 11, 0.1);
  border-left: 4px solid #f59e0b;
  border-radius: 8px;
  margin-top: 12px;
  color: #e2e8f0;
}

/* Backup Plan */
.backup-plan {
  padding: 12px 16px;
  background: rgba(16, 163, 127, 0.1);
  border-left: 4px solid #10a37f;
  border-radius: 8px;
  margin-top: 12px;
  color: #e2e8f0;
}

/* Special Considerations */
.special-considerations {
  padding: 12px 16px;
  background: rgba(59, 130, 246, 0.1);
  border-left: 4px solid #58a6ff;
  border-radius: 8px;
  margin-top: 12px;
  color: #e2e8f0;
}

/* Airway Assessment */
.airway-assessment {
  background: rgba(239, 68, 68, 0.05);
  padding: 16px;
  border-radius: 8px;
  border: 1px solid #565869;
}

/* Lists */
.info-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.info-list li {
  padding: 10px 16px;
  margin-bottom: 8px;
  background: #343541;
  border-left: 3px solid #10a37f;
  border-radius: 6px;
  color: #c5c5d2;
  transition: all 0.2s;
}

.info-list li:hover {
  background: #40414f;
  border-left-color: #10a37f;
}

.block-info {
  padding: 4px 0;
  color: #c5c5d2;
}

/* Nested Fields */
.nested-fields {
  padding-left: 16px;
}

.nested-fields .field-row {
  margin-bottom: 8px;
}

/* Clinical Scores */
.clinical-scores {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 16px;
}

.score-item {
  padding: 16px;
  background: #343541;
  border: 1px solid #565869;
  border-radius: 8px;
  transition: all 0.2s;
}

.score-item:hover {
  border-color: #10a37f;
  background: #40414f;
}

.score-name {
  font-size: 14px;
  font-weight: 700;
  color: #10a37f;
  margin: 0 0 12px 0;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* Risk badge styling - matches AIDocumentRenderer */
.risk-badge {
  padding: 4px 12px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.risk-badge.risk-high {
  background: #ef4444;
  color: white;
}

.risk-badge.risk-moderate {
  background: #f59e0b;
  color: white;
}

.risk-badge.risk-low,
.risk-badge.risk-protective {
  background: #10a37f;
  color: white;
}

/* Referrals */
.referral-item {
  padding: 12px 16px;
  margin-bottom: 8px;
  background: #343541;
  border-left: 3px solid #58a6ff;
  border-radius: 8px;
  color: #c5c5d2;
  transition: all 0.2s;
}

.referral-item:hover {
  background: #40414f;
}

/* Narrative Text */
.narrative {
  white-space: pre-wrap;
  line-height: 1.8;
  color: #c5c5d2;
}

.notes-text {
  white-space: pre-wrap;
  font-family: inherit;
  font-size: 14px;
  line-height: 1.7;
  margin: 0;
  padding: 16px;
  background: #343541;
  border-radius: 8px;
  border: 1px solid #565869;
  color: #c5c5d2;
}

/* Consultation Footer */
.consultation-footer {
  background: #40414f;
  border: 1px solid #565869;
  border-radius: 8px;
  padding: 20px;
}

/* Empty Value */
.empty-value {
  color: #64748b;
  font-style: italic;
}

/* Text elements */
p {
  color: #c5c5d2;
  margin: 8px 0;
  line-height: 1.6;
}

strong {
  color: #e2e8f0;
  font-weight: 600;
}

h3 {
  color: #e2e8f0;
}

/* Ensure all text is visible */
.section-content p,
.section-content div,
.section-content span,
.subsection p,
.subsection div,
.subsection span,
.narrative p,
.field-row,
.field-value,
.nested-fields {
  color: #c5c5d2;
}

/* Responsive */
@media (max-width: 768px) {
  .anesthesia-document {
    padding: 16px;
  }

  .field-row {
    flex-direction: column;
    gap: 4px;
  }

  .field-label {
    min-width: auto;
  }

  .clinical-scores {
    grid-template-columns: 1fr;
  }
}
