# IntelliCare Environment Configuration
# COPY THIS TO .env AND FILL IN YOUR VALUES

# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017

# Security Keys (NEVER COMMIT REAL KEYS!)
JWT_SECRET=your-jwt-secret-here

# AI Services
CLAUDE_API_KEY=your-claude-api-key

# Service Account API Keys (ROTATE EVERY 90 DAYS!)
# These should come from a secure key vault in production
SERVICE_AUTH_AI_KEY=
SERVICE_INCIDENT_RESPONSE_KEY=
SERVICE_AGENT_V4_KEY=
SERVICE_REMINDER_KEY=
SERVICE_AUDIT_LOG_KEY=
SERVICE_COMPLIANCE_KEY=

# Key Management
API_KEY_ROTATION_DAYS=90
API_KEY_WARNING_DAYS=7
API_KEY_MAX_FAILED_ATTEMPTS=5

# Security Settings
ENABLE_API_KEY_ROTATION=true
ENABLE_KEY_MONITORING=true
ENABLE_USAGE_ANALYTICS=true
ENABLE_COMPLIANCE_REPORTING=true

# Key Vault Integration (Production)
# KEY_VAULT_URL=https://your-vault.vault.azure.net/
# KEY_VAULT_CLIENT_ID=
# KEY_VAULT_CLIENT_SECRET=

# AWS KMS Integration (Alternative)
# AWS_KMS_KEY_ID=
# AWS_REGION=us-east-1

# HashiCorp Vault (Alternative)
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=

# Compliance Settings
HIPAA_COMPLIANCE_MODE=true
REQUIRE_KEY_ROTATION=true
AUDIT_ALL_KEY_OPERATIONS=true
ENCRYPT_KEYS_AT_REST=true

# Alert Configuration
SECURITY_ALERT_EMAIL=security@intellicare.health
KEY_ROTATION_NOTICE_EMAIL=devops@intellicare.health