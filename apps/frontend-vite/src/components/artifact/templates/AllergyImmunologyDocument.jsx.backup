              </svg>
              {copiedCardId === 'assessment-plan-section' ? 'Copied!' : 'Copy'}
            </button>
          </div>

          {/* Parse Primary Diagnoses */}
          {(() => {
            const text = document.assessmentAndPlan;
            const primaryMatch = text.match(/Primary Diagnoses:\s*(.+?)(?=Phenotype\/Endotype:|$)/s);
            const phenotypeMatch = text.match(/Phenotype\/Endotype:\s*(.+?)$/s);

            if (primaryMatch) {
              // Extract numbered diagnoses
              const diagnosesText = primaryMatch[1];
              const diagnoses = diagnosesText.split(/\d+\.\s+/).filter(d => d.trim().length > 0);

              return (
                <div>
                  <h3 className="section-title" style={{ fontSize: '18px', marginBottom: '16px' }}>
                    Primary Diagnoses ({diagnoses.length})
                  </h3>
                  <div className="cards-grid">
                    {diagnoses.map((diagnosis, idx) => (
                      <div key={idx} className="ai-card">
                        <div className="card-header">
                          <div className="priority-number">{idx + 1}</div>
                          <div style={{ flex: 1, marginLeft: '16px' }}>
                            <h4 className="card-title" style={{ margin: 0 }}>
                              {highlightText(diagnosis.replace(/,\s*$/, '').trim())}
                            </h4>
                          </div>
                          <button
                            onClick={() => copyCard({ text: diagnosis.trim() }, `diagnosis-${idx}`)}
                            className="copy-btn-inline"
                            title="Copy"
                          >
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                            </svg>
                            {copiedCardId === `diagnosis-${idx}` ? 'Copied!' : 'Copy'}
                          </button>
                        </div>
                      </div>
                    ))}
                  </div>

                  {/* Phenotype/Endotype */}
                  {phenotypeMatch && (
                    <div style={{ marginTop: '24px' }}>
                      <h3 className="section-title" style={{ fontSize: '18px', marginBottom: '16px' }}>
                        Phenotype/Endotype
                      </h3>
                      <div className="ai-card" style={{ borderLeft: '4px solid #10a37f' }}>
                        <div className="card-details">
                          {phenotypeMatch[1].split(',').map((item, idx) => (
                            <div key={idx} className="detail-item" style={{ marginBottom: '8px' }}>
                              <span className="detail-value">• {highlightText(item.trim())}</span>
                            </div>
                          ))}
                        </div>
                      </div>
                    </div>
                  )}
                </div>
              );
            } else {
              // Fallback: show as markdown
              return (
                <div className="doc-section" style={{ background: '#343541', border: '1px solid #565869', borderRadius: '8px', padding: '20px' }}>
                  {renderMarkdownWithHighlight(document.assessmentAndPlan)}
                </div>
              );
            }
          })()}
        </section>
