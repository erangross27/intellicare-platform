.patient-details-document {
  padding: 32px;
  max-width: 900px;
  margin: 0 auto;
  background: transparent;
  color: #ececf1;
  font-family: 'Söhne', system-ui, -apple-system, sans-serif;
}

/* Header */
.patient-details-header {
  margin-bottom: 32px;
  border-bottom: 2px solid rgba(86, 88, 105, 0.3);
  padding-bottom: 24px;
}

.patient-details-header h1 {
  margin: 0 0 16px 0;
  font-size: 28px;
  font-weight: 600;
  color: #ececf1;
}

.patient-name-badge {
  display: flex;
  align-items: center;
  gap: 12px;
}

.patient-name {
  font-size: 20px;
  font-weight: 500;
  color: #10a37f;
}

.patient-status {
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 500;
  text-transform: capitalize;
}

.patient-status.status-active {
  background: rgba(16, 163, 127, 0.15);
  color: #10a37f;
  border: 1px solid rgba(16, 163, 127, 0.3);
}

.patient-status.status-inactive {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
  border: 1px solid rgba(239, 68, 68, 0.3);
}

/* Sections */
.detail-section {
  margin-bottom: 32px;
  background: rgba(32, 33, 35, 0.5);
  border-radius: 8px;
  padding: 24px;
  border: 1px solid rgba(86, 88, 105, 0.3);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 0 0 20px 0;
  font-size: 18px;
  font-weight: 600;
  color: #ececf1;
  padding-bottom: 12px;
  border-bottom: 1px solid rgba(86, 88, 105, 0.3);
}

.section-icon {
  font-size: 20px;
}

/* Info Grid */
.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.info-item.full-width {
  grid-column: 1 / -1;
}

.info-label {
  font-size: 12px;
  font-weight: 500;
  color: #8e8ea0;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.info-value {
  font-size: 15px;
  color: #ececf1;
  font-weight: 400;
  word-break: break-word;
}

.info-value.sensitive {
  font-family: 'Courier New', monospace;
  color: #10a37f;
  font-weight: 500;
}

.info-value.blood-type {
  font-weight: 600;
  color: #ef4444;
  font-size: 16px;
}

/* Footer */
.patient-details-footer {
  margin-top: 32px;
  padding-top: 20px;
  border-top: 1px solid rgba(86, 88, 105, 0.3);
}

.footer-note {
  font-size: 13px;
  color: #8e8ea0;
  font-style: italic;
  text-align: center;
  margin: 0;
}

/* Error State */
.patient-details-error {
  padding: 40px;
  text-align: center;
  color: #ef4444;
  font-size: 16px;
}

/* Responsive Design */
@media (max-width: 768px) {
  .patient-details-document {
    padding: 20px;
  }

  .info-grid {
    grid-template-columns: 1fr;
  }

  .info-item.full-width {
    grid-column: 1;
  }
}
