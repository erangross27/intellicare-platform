{
  "serviceId": "ai-response-cache-service",
  "serviceName": "AI Response Cache Service",
  "description": "Caches AI responses for performance optimization",
  "permissions": [
    "cache:read",
    "cache:write",
    "cache:delete",
    "metrics:write"
  ],
  "allowedClinics": [
    "*"
  ],
  "dataAccessPatterns": [
    "cache.get(key)",
    "cache.set(key, value, ttl)",
    "cache.invalidate(pattern)"
  ],
  "schedules": [
    {
      "cron": "0 */6 * * *",
      "description": "Cache cleanup every 6 hours"
    }
  ],
  "criticality": "low",
  "requiresMFA": false
}